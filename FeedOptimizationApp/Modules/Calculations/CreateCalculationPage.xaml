<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:customcontrols="clr-namespace:FeedOptimizationApp.Helpers"
             xmlns:helpers="clr-namespace:FeedOptimizationApp.Localization"
             xmlns:vm="clr-namespace:FeedOptimizationApp.Modules.Calculations"
             x:Class="FeedOptimizationApp.Modules.Calculations.CreateCalculationPage"
             Title="{helpers:Translate Key=CreateCalculationPage_Title}">

    <ContentPage.Resources>
        <ResourceDictionary>
            <customcontrols:AbsoluteValueConverter x:Key="AbsoluteValueConverter" />
            <customcontrols:NegativeValueColourConverter x:Key="NegativeValueColourConverter" />
            <customcontrols:PercentageValueConverter x:Key="PercentageValueConverter" />
            <customcontrols:PercentageValueConverter2 x:Key="PercentageValueConverter2" />
            <customcontrols:InverseBooleanConverter x:Key="InverseBooleanConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <StackLayout Padding="20" Spacing="10">
        <!-- Navigation Buttons -->
        <ContentView>
            <Grid>
                <!-- Tablet Layout Grid -->
                <Grid x:Name="TabletGrid" ColumnSpacing="20" RowSpacing="20" IsVisible="False">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Button Text="{helpers:Translate Key=CreateCalculationPage_AddAnimalInfoButton}" Grid.Column="0"
                        Command="{Binding SetAnimalInfoActiveTab}" />
                    <Button Text="{helpers:Translate Key=CreateCalculationPage_AddFeedInfoButton}" Grid.Column="1"
                        Command="{Binding SetFeedInfoTabActive}" />
                    <Button Text="{helpers:Translate Key=CreateCalculationPage_OptimizationButton}" Grid.Column="2"
                        Command="{Binding SetOptimizationTabActive}" IsEnabled="{Binding IsResultsButtonVisible}" />
                    <Button Text="{helpers:Translate Key=CreateCalculationPage_ResultsButton}" Grid.Column="3"
                        Command="{Binding SetResultsTabActive}" IsEnabled="{Binding IsResultsButtonVisible}" />
                </Grid>

                <!-- Mobile Layout Grid -->
                <Grid x:Name="MobileGrid" ColumnSpacing="20" RowSpacing="20" IsVisible="True">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Button Text="{helpers:Translate Key=CreateCalculationPage_AddAnimalInfoButton}" Grid.Row="0" Grid.Column="0"
                        Command="{Binding SetAnimalInfoActiveTab}" />
                    <Button Text="{helpers:Translate Key=CreateCalculationPage_AddFeedInfoButton}" Grid.Row="0" Grid.Column="1"
                        Command="{Binding SetFeedInfoTabActive}" />
                    <Button Text="{helpers:Translate Key=CreateCalculationPage_OptimizationButton}" Grid.Row="1" Grid.Column="0"
                        Command="{Binding SetOptimizationTabActive}" IsEnabled="{Binding IsResultsButtonVisible}" />
                    <Button Text="{helpers:Translate Key=CreateCalculationPage_ResultsButton}" Grid.Row="1" Grid.Column="1"
                        Command="{Binding SetResultsTabActive}" IsEnabled="{Binding IsResultsButtonVisible}" />
                </Grid>

                <!-- VisualStateManager -->
                <VisualStateManager.VisualStateGroups>
                    <VisualStateGroup Name="ResponsiveStates">
                        <VisualState Name="Mobile">
                            <VisualState.StateTriggers>
                                <AdaptiveTrigger MinWindowWidth="0" />
                            </VisualState.StateTriggers>
                            <VisualState.Setters>
                                <Setter TargetName="MobileGrid" Property="IsVisible" Value="True" />
                                <Setter TargetName="TabletGrid" Property="IsVisible" Value="False" />
                            </VisualState.Setters>
                        </VisualState>

                        <VisualState Name="Tablet">
                            <VisualState.StateTriggers>
                                <AdaptiveTrigger MinWindowWidth="600" />
                            </VisualState.StateTriggers>
                            <VisualState.Setters>
                                <Setter TargetName="MobileGrid" Property="IsVisible" Value="False" />
                                <Setter TargetName="TabletGrid" Property="IsVisible" Value="True" />
                            </VisualState.Setters>
                        </VisualState>
                    </VisualStateGroup>
                </VisualStateManager.VisualStateGroups>
            </Grid>
        </ContentView>

        <!-- Animal Info Content -->
        <Grid VerticalOptions="FillAndExpand" IsVisible="{Binding AnimalInfoTabIsActive}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <StackLayout Padding="10" Grid.Row="0">
                <Label Text="{helpers:Translate Key=CreateCalculationPage_AnimalInfoHeading}" FontSize="24" FontAttributes="Bold" />
                <Label Text="{helpers:Translate Key=CreateCalculationPage_AnimalInfoSubHeading}" FontSize="16" />
            </StackLayout>
            <ScrollView Grid.Row="2" x:Name="AnimalInfoContentView">
                <StackLayout Padding="10" Spacing="1">
                    <!-- Animal Info Form -->
                    <Grid ColumnSpacing="10" RowSpacing="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- Type -->
                        <Label Text="{helpers:Translate Key=CreateCalculationPage_TypeLabel}" Grid.Row="0" Grid.Column="0" VerticalOptions="Center" />
                        <Picker Title="{helpers:Translate Key=CreateCalculationPage_SelectOption}" Grid.Row="0" Grid.Column="1"
                            ItemsSource="{Binding TranslatedTypes}"
                            ItemDisplayBinding="{Binding Label}"
                            SelectedItem="{Binding SelectedTranslatedType}" />
                        <Label Text="{Binding ValidationErrors[Type]}"
                            TextColor="Red" Grid.Row="1" Grid.Column="1" />

                        <!-- Grazing -->
                        <Label Text="{helpers:Translate Key=CreateCalculationPage_GrazingLabel}" Grid.Row="2" Grid.Column="0" VerticalOptions="Center" />
                        <Picker Title="{helpers:Translate Key=CreateCalculationPage_SelectOption}" Grid.Row="2" Grid.Column="1"
                            ItemsSource="{Binding TranslatedGrazings}"
                            ItemDisplayBinding="{Binding Label}"
                            SelectedItem="{Binding SelectedTranslatedGrazing}" />
                        <Label Text="{Binding ValidationErrors[GrazingId]}"
                            TextColor="Red" Grid.Row="3" Grid.Column="1" />

                        <!-- Body Weight -->
                        <Label Text="{helpers:Translate Key=CreateCalculationPage_BodyWeightLabel}" Grid.Row="4" Grid.Column="0" VerticalOptions="Center" />
                        <Picker Title="{helpers:Translate Key=CreateCalculationPage_SelectOption}" Grid.Row="4" Grid.Column="1"
                            ItemsSource="{Binding BodyWeights}"
                            ItemDisplayBinding="{Binding Name}"
                            SelectedItem="{Binding SelectedBodyWeight}" />
                        <Label Text="{Binding ValidationErrors[BodyWeightId]}"
                            TextColor="Red" Grid.Row="5" Grid.Column="1" />

                        <!-- ADG -->
                        <Label Text="{helpers:Translate Key=CreateCalculationPage_ADGLabel}" Grid.Row="6" Grid.Column="0" VerticalOptions="Center" />
                        <Entry Grid.Row="6" Grid.Column="1" Placeholder="0" Text="{Binding ADG}" Keyboard="Numeric" />

                        <!-- Diet Quality Estimate -->
                        <Label Text="{helpers:Translate Key=CreateCalculationPage_DietQualityLabel}" Grid.Row="7" Grid.Column="0" VerticalOptions="Center" />
                        <Picker Title="{helpers:Translate Key=CreateCalculationPage_SelectOption}" Grid.Row="7" Grid.Column="1"
                            ItemsSource="{Binding TranslatedDietQualityEstimates}"
                            ItemDisplayBinding="{Binding Label}"
                            SelectedItem="{Binding SelectedTranslatedDietQualityEstimate}" />
                        <Label Text="{Binding ValidationErrors[DietQualityEstimateId]}" TextColor="Red" Grid.Row="8" Grid.Column="1" />

                        <!-- Last 8 Weeks of Gestation -->
                        <Label Text="{helpers:Translate Key=CreateCalculationPage_Last8WeeksLabel}" Grid.Row="9" Grid.Column="0" VerticalOptions="Center" />
                        <Switch Grid.Row="9" Grid.Column="1"
                            IsToggled="{Binding IsLast8WeeksOfGestation}" />

                        <!-- Number of Suckling Kids/Lambs -->
                        <Label Text="{helpers:Translate Key=CreateCalculationPage_NumberOfSucklingLabel}" Grid.Row="10" Grid.Column="0" VerticalOptions="Center"
                            IsVisible="{Binding IsNrSucklingsVisible}" />
                        <Picker Title="{helpers:Translate Key=CreateCalculationPage_SelectOption}" Grid.Row="10" Grid.Column="1"
                            ItemsSource="{Binding NrSucklingKidsLambs}"
                            ItemDisplayBinding="{Binding Name}"
                            SelectedItem="{Binding SelectedNumberOfSucklingKidsLambs}"
                            IsVisible="{Binding IsNrSucklingsVisible}" />
                        <Label Text="{Binding ValidationErrors[KidsLambsId]}" TextColor="Red" Grid.Row="11" Grid.Column="1"
                            IsVisible="{Binding IsNrSucklingsVisible}" />
                    </Grid>

                    <!-- Milk and Production Data Section -->
                    <Border Stroke="Gray" Padding="10" Margin="0,20,0,0" IsVisible="{Binding IsMilkAndProductionVisible}">
                        <StackLayout Spacing="2">
                            <Label Text="{helpers:Translate Key=CreateCalculationPage_MilkProductionHeading}" FontSize="18" FontAttributes="Bold" />
                            <Grid ColumnSpacing="10" RowSpacing="1">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <!-- Daily Milk Yield -->
                                <Label Text="{helpers:Translate Key=CreateCalculationPage_DailyMilkYieldLabel}" Grid.Row="0" Grid.Column="0" VerticalOptions="Center" />
                                <Entry Grid.Row="0" Grid.Column="1" Placeholder="0" Text="{Binding DailyMilkYieldValue}" Keyboard="Numeric" />

                                <!-- Fat Content -->
                                <Label Text="{helpers:Translate Key=CreateCalculationPage_FatContentLabel}" Grid.Row="1" Grid.Column="0" VerticalOptions="Center" />
                                <Entry Grid.Row="1" Grid.Column="1" Placeholder="0" Text="{Binding FatContentValue}" Keyboard="Numeric" />
                            </Grid>
                        </StackLayout>
                    </Border>
                </StackLayout>
            </ScrollView>
            <!-- Clear Button -->
            <Button Text="{helpers:Translate Key=CreateCalculationPage_ClearButton}" BackgroundColor="{StaticResource Secondary}" Command="{Binding ClearAnimalInfoCommand}"
                    HorizontalOptions="End" Margin="0,20,0,0" Grid.Row="3" />
        </Grid>

        <!-- Feed Info Content -->
        <Grid VerticalOptions="FillAndExpand" IsVisible="{Binding FeedInfoTabIsActive}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <StackLayout Padding="10" Grid.Row="0">
                <Label Text="{helpers:Translate Key=CreateCalculationPage_FeedInfoHeading}" FontSize="24" FontAttributes="Bold" />
                <Label Text="{helpers:Translate Key=CreateCalculationPage_FeedInfoSubHeading}" FontSize="16" />
            </StackLayout>
            <ScrollView Grid.Row="2"  x:Name="FeedInfoContentView">
                <StackLayout Padding="10">

                    <!-- Entry form for adding new feed -->
                    <Border Stroke="Gray" Padding="10" Margin="0,20,0,0">
                        <toolkit:Expander IsExpanded="{Binding IsAddFeedExpanded}">
                            <toolkit:Expander.Header>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Label Text="{helpers:Translate Key=CreateCalculationPage_AddFeedBoxText}" FontSize="16" FontAttributes="Bold" VerticalOptions="Center" Padding="10,0,0,0" />
                                    <Label Text="+ " FontSize="20" Grid.Column="1" VerticalOptions="Center" HorizontalOptions="End" />
                                </Grid>
                            </toolkit:Expander.Header>
                            <toolkit:Expander.Content>
                                <Grid ColumnSpacing="10" RowSpacing="0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="30" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <customcontrols:AutoCompletePicker
                                        x:Name="FeedPicker"
                                        ItemsSource="{Binding Feeds}"
                                        SelectedItem="{Binding SelectedFeed, Mode=TwoWay}"
                                        DisplayMemberPath="Name"
                                        Text="{Binding SearchText, Mode=TwoWay}"
                                        Placeholder="{helpers:Translate Key=CreateCalculationPage_FeedPickerPlaceholder}"
                                        Grid.Row="0"
                                        Grid.ColumnSpan="2" />

                                    <Label Text="{helpers:Translate Key=CreateCalculationPage_DMLabel}" Grid.Row="1" Grid.Column="0" VerticalOptions="Center" FontSize="14" />
                                    <Entry Placeholder="{helpers:Translate Key=CreateCalculationPage_DMPlaceholder}" Text="{Binding SelectedFeed.DryMatterPercentage}"
                                            Grid.Row="1" Grid.Column="1" FontSize="14" Keyboard="Numeric" />

                                    <Label Text="{helpers:Translate Key=CreateCalculationPage_CPLabel}" Grid.Row="2" Grid.Column="0" VerticalOptions="Center" FontSize="14" />
                                    <Entry Placeholder="{helpers:Translate Key=CreateCalculationPage_CPPlaceholder}" Text="{Binding SelectedFeed.CPPercentage}"
                                            Grid.Row="2" Grid.Column="1" FontSize="14" Keyboard="Numeric" />

                                    <Label Text="{helpers:Translate Key=CreateCalculationPage_MELabel}" Grid.Row="3" Grid.Column="0" VerticalOptions="Center" FontSize="14" />
                                    <Entry Placeholder="{helpers:Translate Key=CreateCalculationPage_MEPlaceholder}" Text="{Binding SelectedFeed.MEMJKg}"
                                            Grid.Row="3" Grid.Column="1" FontSize="14" Keyboard="Numeric" />

                                    <Label Text="{helpers:Translate Key=CreateCalculationPage_PriceLabel}" Grid.Row="4" Grid.Column="0" VerticalOptions="Center" FontSize="14" />
                                    <Entry Placeholder="{helpers:Translate Key=CreateCalculationPage_PricePlaceholder}" Text="{Binding Price}"
                                            Grid.Row="4" Grid.Column="1" FontSize="14" Keyboard="Numeric" />

                                    <Label Text="{helpers:Translate Key=CreateCalculationPage_IntakeLabel}" Grid.Row="5" Grid.Column="0" VerticalOptions="Center" FontSize="14" />
                                    <Entry Placeholder="{helpers:Translate Key=CreateCalculationPage_IntakePlaceholder}" Text="{Binding Intake}"
                                            Grid.Row="5" Grid.Column="1" FontSize="14" Keyboard="Numeric" />

                                    <Label Text="{helpers:Translate Key=CreateCalculationPage_MinLimitLabel}" Grid.Row="6" Grid.Column="0" VerticalOptions="Center" FontSize="14" />
                                    <Entry Placeholder="{helpers:Translate Key=CreateCalculationPage_MinLimitPlaceholder}" Text="{Binding MinLimit}"
                                            Grid.Row="6" Grid.Column="1" FontSize="14" Keyboard="Numeric" />

                                    <Label Text="{helpers:Translate Key=CreateCalculationPage_MaxLimitLabel}" Grid.Row="7" Grid.Column="0" VerticalOptions="Center" FontSize="14" />
                                    <Entry Placeholder="{helpers:Translate Key=CreateCalculationPage_MaxLimitPlaceholder}" Text="{Binding MaxLimit}"
                                            Grid.Row="7" Grid.Column="1" FontSize="14" Keyboard="Numeric" />

                                    <StackLayout Orientation="Horizontal" HorizontalOptions="Start" Grid.Row="8" Grid.ColumnSpan="1" Spacing="10">
                                        <Button Text="{helpers:Translate Key=CreateCalculationPage_ClearButton}" BackgroundColor="{StaticResource Secondary}" Command="{Binding ClearFeedCommand}" />
                                    </StackLayout>
                                    <StackLayout Orientation="Horizontal" HorizontalOptions="End" Grid.Row="8" Grid.ColumnSpan="2" Spacing="10">
                                        <Button Text="{helpers:Translate Key=CreateCalculationPage_AddButton}" Command="{Binding AddFeedCommand}" BackgroundColor="{StaticResource Primary}" />
                                    </StackLayout>
                                </Grid>
                            </toolkit:Expander.Content>
                        </toolkit:Expander>
                    </Border>

                    <!-- List of stored feeds -->
                    <StackLayout BindableLayout.ItemsSource="{Binding StoredFeeds}">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate>
                                <Border Stroke="Gray" Padding="10" Margin="0,10,0,0">
                                    <toolkit:Expander>
                                        <toolkit:Expander.Header>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <!--<Label Text="{Binding Feed.Name, StringFormat='{Binding CreateCalculationPage_FeedLabel}: {0}'}"
                                                        FontSize="16" FontAttributes="Bold" VerticalOptions="Center" Padding="10,2,0,2" />-->
                                                <Label FontSize="16" FontAttributes="Bold" VerticalOptions="Center" Padding="10,2,0,2">
                                                    <Label.FormattedText>
                                                        <FormattedString>
                                                            <Span Text="{helpers:Translate Key=CreateCalculationPage_FeedLabel}" />
                                                            <Span Text=": " />
                                                            <Span Text="{Binding Feed.Name}" />
                                                        </FormattedString>
                                                    </Label.FormattedText>
                                                </Label>
                                                <Label Text="▼" FontSize="16" Grid.Column="1" VerticalOptions="Center" HorizontalOptions="End" />
                                            </Grid>
                                        </toolkit:Expander.Header>
                                        <toolkit:Expander.Content>
                                            <Grid ColumnSpacing="10" RowSpacing="0">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="30" />
                                                </Grid.RowDefinitions>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="246" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <Label Text="{helpers:Translate Key=CreateCalculationPage_DMLabel}"
                                                    Grid.Row="0" Grid.Column="0" VerticalOptions="Center" FontSize="14" />
                                                <Entry Text="{Binding DM}" Grid.Row="0" Grid.Column="1" IsEnabled="False" FontSize="14" />

                                                <Label Text="{helpers:Translate Key=CreateCalculationPage_CPLabel}"
                                                    Grid.Row="1" Grid.Column="0" VerticalOptions="Center" FontSize="14" />
                                                <Entry Text="{Binding CPDM}" Grid.Row="1" Grid.Column="1" IsEnabled="False" FontSize="14" />

                                                <Label Text="{helpers:Translate Key=CreateCalculationPage_MELabel}"
                                                    Grid.Row="2" Grid.Column="0" VerticalOptions="Center" FontSize="14" />
                                                <Entry Text="{Binding MEMJKGDM}" Grid.Row="2" Grid.Column="1" IsEnabled="False" FontSize="14" />

                                                <Label Text="{helpers:Translate Key=CreateCalculationPage_PriceLabel}"
                                                    Grid.Row="3" Grid.Column="0" VerticalOptions="Center" FontSize="14" />
                                                <Entry Text="{Binding Price}" Grid.Row="3" Grid.Column="1" IsEnabled="False" FontSize="14" />

                                                <Label Text="{helpers:Translate Key=CreateCalculationPage_IntakeLabel}"
                                                    Grid.Row="4" Grid.Column="0" VerticalOptions="Center" FontSize="14" />
                                                <Entry Text="{Binding Intake, Mode=TwoWay}"
                                                   IsEnabled="{Binding Path=BindingContext.IsStoredFeedEditable, Source={x:Reference FeedInfoContentView}}"
                                                   Grid.Row="4" Grid.Column="1" FontSize="14" Keyboard="Numeric" />

                                                <Label Text="{helpers:Translate Key=CreateCalculationPage_MinLimitLabel}"
                                                    Grid.Row="5" Grid.Column="0" VerticalOptions="Center" FontSize="14" />
                                                <Entry Text="{Binding MinLimit}" Grid.Row="5" Grid.Column="1" IsEnabled="False" FontSize="14" />

                                                <Label Text="{helpers:Translate Key=CreateCalculationPage_MaxLimitLabel}"
                                                    Grid.Row="6" Grid.Column="0" VerticalOptions="Center" FontSize="14" />
                                                <Entry Text="{Binding MaxLimit}" Grid.Row="6" Grid.Column="1" IsEnabled="False" FontSize="14" />

                                                <StackLayout Orientation="Horizontal" HorizontalOptions="Start" Grid.Row="7" Grid.ColumnSpan="1" Spacing="10">
                                                    <Button Text="{helpers:Translate Key=CreateCalculationPage_EditButton}"
                                                        Command="{Binding Path=BindingContext.EditStoredFeedCommand, Source={x:Reference FeedInfoContentView}}"
                                                        CommandParameter="{Binding .}"
                                                        IsEnabled="{Binding Path=BindingContext.IsStoredFeedEditable, Source={x:Reference FeedInfoContentView}, Converter={StaticResource InverseBooleanConverter}}" />
                                                </StackLayout>
                                                <StackLayout Orientation="Horizontal" HorizontalOptions="End" Grid.Row="7" Grid.ColumnSpan="2" Spacing="10">
                                                    <Button Text="{helpers:Translate Key=CreateCalculationPage_SaveButton}"
                                                        Command="{Binding Path=BindingContext.SaveStoredFeedCommand, Source={x:Reference FeedInfoContentView}}"
                                                        CommandParameter="{Binding .}"
                                                        IsEnabled="{Binding Path=BindingContext.IsStoredFeedEditable, Source={x:Reference FeedInfoContentView}}" />
                                                </StackLayout>
                                            </Grid>
                                        </toolkit:Expander.Content>
                                    </toolkit:Expander>
                                </Border>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </StackLayout>
                </StackLayout>
            </ScrollView>
            <!-- Reset Button -->
            <Button Text="{helpers:Translate Key=CreateCalculationPage_ResetButton}" BackgroundColor="{StaticResource Secondary}" Command="{Binding ResetFeedInfoCommand}"
                HorizontalOptions="End" Margin="0,20,0,0" Grid.Row="3" />
        </Grid>

        <!-- Optimization Content -->
        <Grid VerticalOptions="FillAndExpand" IsVisible="{Binding OptimizationTabIsActive}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <StackLayout Padding="10" Grid.Row="0">
                <Label Text="{helpers:Translate Key=CreateCalculationPage_OptimizationHeading}" FontSize="24" FontAttributes="Bold" HorizontalOptions="Center" />
            </StackLayout>
            <ScrollView Grid.Row="1" x:Name="OptimizationContentView">
                <StackLayout Spacing="20">

                    <!-- Animal Data Section -->
                    <StackLayout>
                        <Label Text="{helpers:Translate Key=CreateCalculationPage_AnimalDataHeading}" FontSize="18" FontAttributes="Bold" TextColor="{StaticResource Primary}" />
                        <Grid Margin="2" ColumnSpacing="10" RowSpacing="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <!-- Animal Data Headers -->
                            <Label Text="{helpers:Translate Key=CreateCalculationPage_TypeLabel}" Grid.Row="0" Grid.Column="0" FontSize="12" />
                            <Label Text="{helpers:Translate Key=CreateCalculationPage_GrazingLabel}" Grid.Row="1" Grid.Column="0" FontSize="12" />
                            <Label Text="{helpers:Translate Key=CreateCalculationPage_BodyWeightLabel}" Grid.Row="2" Grid.Column="0" FontSize="12" />
                            <Label Text="{helpers:Translate Key=CreateCalculationPage_ADGLabel}" Grid.Row="3" Grid.Column="0" FontSize="12" />
                            <Label Text="{helpers:Translate Key=CreateCalculationPage_DietQualityLabel}" Grid.Row="4" Grid.Column="0" FontSize="12" />
                            <Label Text="{helpers:Translate Key=CreateCalculationPage_Last8WeeksLabel}" Grid.Row="5" Grid.Column="0" FontSize="12" />
                            <Label Text="{helpers:Translate Key=CreateCalculationPage_NumberOfSucklingLabel}" Grid.Row="6" Grid.Column="0" FontSize="12" IsVisible="{Binding IsNrSucklingsVisible}" />
                            <Label Text="{helpers:Translate Key=CreateCalculationPage_DailyMilkYieldLabel}" Grid.Row="7" Grid.Column="0" FontSize="12" IsVisible="{Binding IsMilkAndProductionVisible}"/>
                            <Label Text="{helpers:Translate Key=CreateCalculationPage_FatContentLabel}" Grid.Row="8" Grid.Column="0" FontSize="12" IsVisible="{Binding IsMilkAndProductionVisible}"/>

                            <!-- Animal Data Values -->
                            <Label Text="{Binding SelectedTranslatedType.Label}" Grid.Row="0" Grid.Column="1" FontSize="12" />
                            <Label Text="{Binding SelectedTranslatedGrazing.Label}" Grid.Row="1" Grid.Column="1" FontSize="12" />
                            <Label Text="{Binding SelectedBodyWeight.Name}" Grid.Row="2" Grid.Column="1" FontSize="12" />
                            <Label Text="{Binding ADG}" Grid.Row="3" Grid.Column="1" FontSize="12" />
                            <Label Text="{Binding SelectedTranslatedDietQualityEstimate.Label}" Grid.Row="4" Grid.Column="1" FontSize="12" />
                            <Label Text="{Binding IsLast8WeeksOfGestation}" Grid.Row="5" Grid.Column="1" FontSize="12" />
                            <Label Text="{Binding SelectedNumberOfSucklingKidsLambs.Name}" Grid.Row="6" Grid.Column="1" FontSize="12" IsVisible="{Binding IsNrSucklingsVisible}" />
                            <Label Text="{Binding DailyMilkYieldValue}" Grid.Row="7" Grid.Column="1" FontSize="12" IsVisible="{Binding IsMilkAndProductionVisible}"/>
                            <Label Text="{Binding FatContentValue, Converter={StaticResource PercentageValueConverter2}}"
                                     Grid.Row="8" Grid.Column="1" FontSize="12" IsVisible="{Binding IsMilkAndProductionVisible}"/>
                        </Grid>
                    </StackLayout>

                    <!-- Requirements Section -->
                    <StackLayout>
                        <Label Text="{helpers:Translate Key=CreateCalculationPage_RequirementsHeading}" FontSize="18" FontAttributes="Bold" TextColor="{StaticResource Primary}" />
                        <Grid Margin="2" ColumnSpacing="10" RowSpacing="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />

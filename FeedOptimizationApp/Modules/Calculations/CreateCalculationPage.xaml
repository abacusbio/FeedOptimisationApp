                            </Grid.ColumnDefinitions>

                            <Button Text="{helpers:Translate Key=CreateCalculationPage_SaveButton}" Grid.Row="1" Grid.Column="1" HorizontalOptions="End" VerticalOptions="End" Margin="10"
                                    Command="{Binding SaveResultsCommand}" BackgroundColor="{StaticResource Primary}" />
                        </Grid>
                    </StackLayout>
                </StackLayout>
            </ScrollView>
        </Grid>
    </StackLayout>
</ContentPage>
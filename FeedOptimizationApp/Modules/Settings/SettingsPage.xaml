<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:helpers="clr-namespace:FeedOptimizationApp.Localization"
             x:Class="FeedOptimizationApp.Modules.Settings.SettingsPage">

    <StackLayout Padding="20" Spacing="20">

        <!-- Page Title -->
        <Label Text="{helpers:Translate Key=SettingsPage_Heading}"
               FontSize="24"
               HorizontalOptions="Center"
               Margin="0,0,0,20" />

        <!-- Language Picker -->
        <Label Text="{helpers:Translate Key=SettingsPage_SelectLanguageLabel}" FontSize="18" />
        <Picker Title="{helpers:Translate Key=SettingsPage_SelectOption}"
                ItemsSource="{Binding Languages}"
                SelectedItem="{Binding SelectedLanguage}"
                ItemDisplayBinding="{Binding Label}"
                FontSize="16" />

        <!-- Country Picker -->
        <Label Text="{helpers:Translate Key=SettingsPage_SelectCountryLabel}" FontSize="18" />
        <Picker Title="{helpers:Translate Key=SettingsPage_SelectOption}"
                ItemsSource="{Binding Countries}"
                SelectedItem="{Binding SelectedCountry}"
                ItemDisplayBinding="{Binding Label}"
                FontSize="16" />

        <!-- Species Picker -->
        <Label Text="{helpers:Translate Key=SettingsPage_SelectSpeciesLabel}" FontSize="18" />
        <Picker Title="{helpers:Translate Key=SettingsPage_SelectOption}"
                ItemsSource="{Binding SpeciesList}"
                SelectedItem="{Binding SelectedSpecies}"
                ItemDisplayBinding="{Binding Label}"
                FontSize="16" />

        <!-- Action Buttons -->
        <StackLayout Orientation="Horizontal" HorizontalOptions="Center" Spacing="20" Margin="0,30,0,0">
            <Button Text="{helpers:Translate Key=SettingsPage_CancelButton}"
                    Command="{Binding CancelCommand}"
                    BackgroundColor="{StaticResource Secondary}" />
            <Button Text="{helpers:Translate Key=SettingsPage_SaveButton}"
                    Command="{Binding SaveCommand}"
                    BackgroundColor="{StaticResource Primary}" />
        </StackLayout>

    </StackLayout>
</ContentPage>
